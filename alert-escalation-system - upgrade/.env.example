# =============================================================================
# LOCAL DEVELOPMENT (default focus — production comes later)
# =============================================================================
# Prerequisites: PostgreSQL + Redis running locally (defaults below).
#
# Do NOT set NODE_ENV=production locally unless you are testing prod-style auth.
# API keys (ADMIN_API_KEY / INGEST_API_KEY) are optional locally — omit them to use
# the simulator and loadtest without headers. Set ENFORCE_API_KEYS=true when you
# want to require keys like production.
#
# Minimal local flow (one terminal — ingest + rules):
#   npm run local:stack
# Then: npm run dev  (simulator — optional SIM_DEVICE_IDS=28,29  SIM_FORCE_VIOLATION=true)
#
# All processes (API + every worker) in one terminal:
#   npm run local:stack:full
# =============================================================================

PORT=5000

# If you see "invalid input syntax for type integer" for device IDs like test-device-1,
# run DB migrations once: npm run migrate:prod  (updates device_id columns to VARCHAR)
#
# Optional locally. Uncomment when you want API-key checks (8+ chars each).
# ADMIN_API_KEY=local-dev-admin-key-min-8-chars
# INGEST_API_KEY=local-dev-ingest-key-min-8-chars
# ENFORCE_API_KEYS=true

JSON_BODY_LIMIT=256kb

# CORS: optional. Non-production allows localhost:3000/3001/5173 by default for the Next.js/Vite dashboard.
# Override or add origins:
# CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# TRUST_PROXY=true
# METRICS_REQUIRE_AUTH=true

DB_HOST=localhost
DB_PORT=5432
DB_NAME=alert_escalation_db
DB_USER=postgres
DB_PASSWORD=your-database-password

DB_LOGGING=false
DB_POOL_MAX=30
DB_POOL_MIN=2
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=10000

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

PACKET_DEDUPE_TTL_SECONDS=120
METRIC_EVAL_CONCURRENCY=8
NOTIFICATION_MAX_RETRIES=3

# Email — optional until you test notifications locally
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=alerts@example.com
EMAIL_PASS=replace-password
